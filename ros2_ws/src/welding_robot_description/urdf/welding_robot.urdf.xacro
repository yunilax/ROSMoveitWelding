<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="welding_robot">

  <xacro:property name="pi" value="3.14159265359"/>

  <!-- Simplified 6-DOF arm + welding torch link (for MoveIt / Gazebo learning) -->
  <link name="base_link">
    <visual>
      <geometry><cylinder length="0.08" radius="0.12"/></geometry>
      <material name="dark_grey"><color rgba="0.2 0.2 0.22 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder length="0.08" radius="0.12"/></geometry>
    </collision>
    <inertial>
      <mass value="5.0"/>
      <inertia ixx="0.02" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.02"/>
    </inertial>
  </link>

  <link name="link_1">
    <visual>
      <geometry><box size="0.1 0.1 0.35"/></geometry>
      <origin xyz="0 0 0.175"/>
      <material name="orange"><color rgba="0.9 0.45 0.1 1"/></material>
    </visual>
    <collision>
      <geometry><box size="0.1 0.1 0.35"/></geometry>
      <origin xyz="0 0 0.175"/>
    </collision>
    <inertial>
      <origin xyz="0 0 0.175"/>
      <mass value="8.0"/>
      <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.02"/>
    </inertial>
  </link>

  <joint name="joint_1" type="revolute">
    <parent link="base_link"/>
    <child link="link_1"/>
    <origin xyz="0 0 0.04" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="100" velocity="2.0"/>
  </joint>

  <link name="link_2">
    <visual>
      <geometry><box size="0.08 0.35 0.08"/></geometry>
      <origin xyz="0 0.175 0"/>
      <material name="orange"/>
    </visual>
    <collision>
      <geometry><box size="0.08 0.35 0.08"/></geometry>
      <origin xyz="0 0.175 0"/>
    </collision>
    <inertial>
      <origin xyz="0 0.175 0"/>
      <mass value="6.0"/>
      <inertia ixx="0.04" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.04"/>
    </inertial>
  </link>

  <joint name="joint_2" type="revolute">
    <parent link="link_1"/>
    <child link="link_2"/>
    <origin xyz="0 0 0.35" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0" upper="2.0" effort="100" velocity="2.0"/>
  </joint>

  <link name="link_3">
    <visual>
      <geometry><box size="0.07 0.3 0.07"/></geometry>
      <origin xyz="0 0.15 0"/>
      <material name="orange"/>
    </visual>
    <collision>
      <geometry><box size="0.07 0.3 0.07"/></geometry>
      <origin xyz="0 0.15 0"/>
    </collision>
    <inertial>
      <origin xyz="0 0.15 0"/>
      <mass value="4.0"/>
      <inertia ixx="0.03" ixy="0" ixz="0" iyy="0.015" iyz="0" izz="0.03"/>
    </inertial>
  </link>

  <joint name="joint_3" type="revolute">
    <parent link="link_2"/>
    <child link="link_3"/>
    <origin xyz="0 0.35 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.5" upper="2.5" effort="80" velocity="2.0"/>
  </joint>

  <link name="link_4">
    <visual>
      <geometry><cylinder length="0.12" radius="0.045"/></geometry>
      <origin xyz="0 0 0.06"/>
      <material name="grey"><color rgba="0.5 0.5 0.52 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder length="0.12" radius="0.045"/></geometry>
      <origin xyz="0 0 0.06"/>
    </collision>
    <inertial>
      <origin xyz="0 0 0.06"/>
      <mass value="2.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.005"/>
    </inertial>
  </link>

  <joint name="joint_4" type="revolute">
    <parent link="link_3"/>
    <child link="link_4"/>
    <origin xyz="0 0.3 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="40" velocity="3.0"/>
  </joint>

  <link name="link_5">
    <visual>
      <geometry><cylinder length="0.1" radius="0.04"/></geometry>
      <origin xyz="0 0 0.05"/>
      <material name="grey"/>
    </visual>
    <collision>
      <geometry><cylinder length="0.1" radius="0.04"/></geometry>
      <origin xyz="0 0 0.05"/>
    </collision>
    <inertial>
      <origin xyz="0 0 0.05"/>
      <mass value="1.5"/>
      <inertia ixx="0.008" ixy="0" ixz="0" iyy="0.008" iyz="0" izz="0.003"/>
    </inertial>
  </link>

  <joint name="joint_5" type="revolute">
    <parent link="link_4"/>
    <child link="link_5"/>
    <origin xyz="0 0 0.12" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0" upper="2.0" effort="30" velocity="3.0"/>
  </joint>

  <!-- Tool flange + welding torch (TCP at torch tip) -->
  <link name="tool0"/>
  <joint name="joint_6" type="revolute">
    <parent link="link_5"/>
    <child link="tool0"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.28" upper="6.28" effort="20" velocity="4.0"/>
  </joint>

  <link name="welding_torch">
    <visual>
      <geometry><cylinder length="0.18" radius="0.018"/></geometry>
      <origin xyz="0 0 0.09"/>
      <material name="copper"><color rgba="0.85 0.55 0.25 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder length="0.18" radius="0.018"/></geometry>
      <origin xyz="0 0 0.09"/>
    </collision>
    <inertial>
      <origin xyz="0 0 0.09"/>
      <mass value="0.8"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.0005"/>
    </inertial>
  </link>

  <joint name="torch_fixed" type="fixed">
    <parent link="tool0"/>
    <child link="welding_torch"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- TCP frame at torch tip (for welding path / MoveIt end-effector) -->
  <link name="tcp"/>
  <joint name="tcp_joint" type="fixed">
    <parent link="welding_torch"/>
    <child link="tcp"/>
    <origin xyz="0 0 0.18" rpy="0 0 0"/>
  </joint>

</robot>
